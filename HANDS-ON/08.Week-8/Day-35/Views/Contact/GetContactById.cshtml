@model ContactInfo

<h2>Contact Details</h2>

@if (Model != null)
{
    <table class="table table-bordered">

        <tr>
            <th>Name</th>
            <td>@Model.FirstName @Model.LastName</td>
        </tr>

        <tr>
            <th>Email</th>
            <td>@Model.EmailId</td>
        </tr>

        <tr>
            <th>Mobile</th>
            <td>@Model.MobileNo</td>
        </tr>

        <tr>
            <th>Designation</th>
            <td>@Model.Designation</td>
        </tr>

        <tr>
            <th>Company</th>
            <td>@Model.CompanyName</td>
        </tr>

        <tr>
            <th>Department</th>
            <td>@Model.DepartmentName</td>
        </tr>

    </table>

    <a asp-action="ShowContacts" class="btn btn-secondary">Back</a>
}
else
{
    <div class="text-danger">
        Contact not found
    </div>

    <a asp-action="ShowContacts" class="btn btn-secondary">Back</a>
}