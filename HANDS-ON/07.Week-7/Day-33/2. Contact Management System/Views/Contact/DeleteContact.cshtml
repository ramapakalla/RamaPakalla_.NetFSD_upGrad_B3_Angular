@model WebApplication8.Models.ContactInfo

<h2>Delete Contact</h2>

<h4>Are you sure you want to delete this contact?</h4>

<form asp-action="DeleteConfirmed" method="post">

    <input type="hidden" name="id" value="@Model.ContactId" />

    <p>
        <strong>@Model.FirstName @Model.LastName</strong>
    </p>

    <button type="submit" class="btn btn-danger">Delete</button>

    <a asp-action="ShowContacts" class="btn btn-secondary">Cancel</a>

</form>