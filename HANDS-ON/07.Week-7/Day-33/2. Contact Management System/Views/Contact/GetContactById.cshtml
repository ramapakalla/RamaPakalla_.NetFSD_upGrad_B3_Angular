@model ContactInfo

<h2>Contact Details</h2>

<table class="table table-bordered">

<tr>
    <th>Name</th>
    <td>@Model.FirstName @Model.LastName</td>
</tr>

<tr>
    <th>Email</th>
    <td>@Model.EmailId</td>
</tr>

<tr>
    <th>Mobile</th>
    <td>@Model.MobileNo</td>
</tr>

<tr>
    <th>Designation</th>
    <td>@Model.Designation</td>
</tr>

<tr>
    <th>Company</th>
    <td>@Model.Company.CompanyName</td>
</tr>

<tr>
    <th>Department</th>
    <td>@Model.Department.DepartmentName</td>
</tr>

</table>

<a asp-action="ShowContacts">Back</a>